  "datasets": [
    {
      "name": "ds_kpi",
      "displayName": "KPI Summary",
      "queryLines": [
        "SELECT COUNT(*) AS total_runs, SUM(CASE WHEN jr.result_state = 'SUCCEEDED' THEN 1 ELSE 0 END) AS successful_runs, SUM(CASE WHEN jr.result_state != 'SUCCEEDED' THEN 1 ELSE 0 END) AS failed_runs, COALESCE(ROUND((SELECT AVG(jrt.execution_duration_seconds) FROM system.lakeflow.job_task_run_timeline jrt JOIN system.lakeflow.jobs j2 ON jrt.job_id = j2.job_id WHERE j2.name LIKE '%PostNL Retail Pipeline%' AND jrt.period_start_time >= date_sub(current_date(), 7)) / 60.0, 2), 0) AS avg_task_duration_min FROM system.lakeflow.job_run_timeline AS jr JOIN system.lakeflow.jobs AS j ON jr.job_id = j.job_id WHERE j.name LIKE '%PostNL Retail Pipeline%' AND jr.period_start_time >= date_sub(current_date(), 7) AND jr.result_state IS NOT NULL\n"
      ]
    },
    {
      "name": "ds_run_trends",
      "displayName": "Job Run Trends",
      "queryLines": [
        "SELECT DATE_TRUNC('DAY', jr.period_start_time) AS run_date, jr.result_state, COUNT(*) AS run_count FROM system.lakeflow.job_run_timeline AS jr JOIN system.lakeflow.jobs AS j ON jr.job_id = j.job_id WHERE j.name LIKE '%PostNL Retail Pipeline%' AND jr.period_start_time >= date_sub(current_date(), 14) AND jr.result_state IS NOT NULL GROUP BY ALL ORDER BY run_date DESC\n"
      ]
    },
    {
      "name": "ds_duration",
      "displayName": "Job Run Duration",
      "queryLines": [
        "SELECT DATE_TRUNC('DAY', jr.period_start_time) AS run_date, ROUND(AVG(TIMESTAMPDIFF(SECOND, jr.period_start_time, jr.period_end_time)) / 60.0, 2) AS avg_duration_min, ROUND(MAX(TIMESTAMPDIFF(SECOND, jr.period_start_time, jr.period_end_time)) / 60.0, 2) AS max_duration_min, COUNT(*) AS run_count FROM system.lakeflow.job_run_timeline AS jr JOIN system.lakeflow.jobs AS j ON jr.job_id = j.job_id WHERE j.name LIKE '%PostNL Retail Pipeline%' AND jr.period_start_time >= date_sub(current_date(), 14) AND jr.result_state IS NOT NULL GROUP BY ALL ORDER BY run_date DESC\n"
      ]
    },
    {
      "name": "ds_task_trends",
      "displayName": "Task Duration Trends",
      "queryLines": [
        "SELECT DATE_TRUNC('DAY', jrt.period_start_time) AS run_date, jrt.task_key, ROUND(AVG(jrt.execution_duration_seconds), 1) AS avg_exec_seconds, COUNT(*) AS run_count FROM system.lakeflow.job_task_run_timeline AS jrt JOIN system.lakeflow.jobs AS j ON jrt.job_id = j.job_id WHERE j.name LIKE '%PostNL Retail Pipeline%' AND jrt.period_start_time >= date_sub(current_date(), 14) AND jrt.result_state IS NOT NULL GROUP BY ALL ORDER BY run_date DESC, jrt.task_key\n"
      ]
    },
    {
      "name": "ds_dq",
      "displayName": "Data Quality Log",
      "queryLines": [
        "SELECT check_timestamp, total_records, clean_records, quarantined_records, quarantine_rate FROM serverless_stable_a7uda0_catalog.postnl_monitoring.data_quality_log ORDER BY check_timestamp DESC LIMIT 50\n"
      ]
    },
    {
      "name": "ds_health",
      "displayName": "Pipeline Health",
      "queryLines": [
        "SELECT snapshot_ts, bronze_record_count, silver_txn_count, silver_items_count, avg_quarantine_rate_pct, successful_batches, last_ingestion_ts FROM serverless_stable_a7uda0_catalog.postnl_monitoring.gold_pipeline_health ORDER BY snapshot_ts DESC LIMIT 1\n"
      ]
    },
    {
      "name": "ds_daily_cost",
      "displayName": "Daily Cost",
      "queryLines": [
        "SELECT u.usage_date, u.sku_name, ROUND(SUM(u.usage_quantity), 4) AS total_dbus, COALESCE(ROUND(SUM(u.usage_quantity * lp.pricing.default), 2), 0) AS estimated_cost_usd FROM system.billing.usage AS u LEFT JOIN system.billing.list_prices AS lp ON u.cloud = lp.cloud AND u.sku_name = lp.sku_name AND u.usage_start_time BETWEEN lp.price_start_time AND COALESCE(lp.price_end_time, TIMESTAMP '2099-12-31') WHERE u.usage_date >= date_sub(current_date(), 30) AND (u.sku_name LIKE '%SERVERLESS%' OR u.sku_name LIKE '%SQL%' OR u.sku_name LIKE '%JOBS%') GROUP BY u.usage_date, u.sku_name ORDER BY u.usage_date DESC\n"
      ]
    },
    {
      "name": "ds_project_cost",
      "displayName": "Project-Tagged Cost",
      "queryLines": [
        "SELECT u.usage_date, u.sku_name, ROUND(SUM(u.usage_quantity), 4) AS total_dbus, COALESCE(ROUND(SUM(u.usage_quantity * lp.pricing.default), 2), 0) AS estimated_cost_usd FROM system.billing.usage AS u LEFT JOIN system.billing.list_prices AS lp ON u.cloud = lp.cloud AND u.sku_name = lp.sku_name AND u.usage_start_time BETWEEN lp.price_start_time AND COALESCE(lp.price_end_time, TIMESTAMP '2099-12-31') WHERE u.usage_date >= date_sub(current_date(), 30) AND u.custom_tags.project = 'postnl-retail-monitoring' GROUP BY u.usage_date, u.sku_name ORDER BY u.usage_date DESC\n"
      ]
    },
    {
      "name": "ds_cost_by_sku",
      "displayName": "Cost by SKU",
      "queryLines": [
        "SELECT u.sku_name, COALESCE(ROUND(SUM(u.usage_quantity * lp.pricing.default), 2), 0) AS total_cost_usd FROM system.billing.usage AS u LEFT JOIN system.billing.list_prices AS lp ON u.cloud = lp.cloud AND u.sku_name = lp.sku_name AND u.usage_start_time BETWEEN lp.price_start_time AND COALESCE(lp.price_end_time, TIMESTAMP '2099-12-31') WHERE u.usage_date >= date_sub(current_date(), 30) AND u.custom_tags.project = 'postnl-retail-monitoring' GROUP BY u.sku_name HAVING SUM(u.usage_quantity * lp.pricing.default) > 0 ORDER BY total_cost_usd DESC LIMIT 8\n"
      ]
    }
  ]
}